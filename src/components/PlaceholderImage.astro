---
interface Props {
  label: string;
  class?: string;
  variant?: 'hero' | 'room' | 'gallery';
}

const { label, class: className = '', variant = 'gallery' } = Astro.props;
const heights = { hero: 'min-h-[420px]', room: 'aspect-[4/3]', gallery: 'aspect-square' };
---

<div
  class:list={[
    'relative flex items-end overflow-hidden rounded-xl bg-gradient-to-br from-ocean-700 via-ocean-600 to-ocean-800 p-4',
    heights[variant],
    className,
  ]}
  role="img"
  aria-label={label}
>
  <div class="absolute inset-0 opacity-20" aria-hidden="true">
    <svg class="h-full w-full" viewBox="0 0 400 300" preserveAspectRatio="xMidYMid slice">
      <path fill="currentColor" class="text-sand-100" d="M0 200 Q100 120 200 180 T400 140 L400 300 L0 300 Z" />
      <circle cx="320" cy="60" r="40" fill="currentColor" class="text-sand-200 opacity-60" />
    </svg>
  </div>
  <span class="relative z-10 text-sm font-medium text-sand-50/90">{label}</span>
</div>

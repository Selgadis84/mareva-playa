---
import type { Locale } from '../i18n';
import { formatPrice } from '../i18n';

interface Room {
  id: string;
  name: Record<Locale, string>;
  description: Record<Locale, string>;
  priceMxn: number;
  capacity: number;
  beds: Record<Locale, string>;
  image: string;
}

interface Props {
  room: Room;
  locale: Locale;
  labels: {
    perNight: string;
    idealFor: string;
    guests: string;
  };
  contactHref: string;
  reserveLabel: string;
}

const { room, locale, labels, contactHref, reserveLabel } = Astro.props;
const usePlaceholder = room.image.endsWith('.svg');
---

<article class="group flex flex-col overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-sand-200 transition hover:shadow-md">
  {usePlaceholder ? (
    <div
      class="aspect-[4/3] bg-gradient-to-br from-ocean-700 via-ocean-600 to-ocean-800 p-6 flex items-end"
      role="img"
      aria-label={room.name[locale]}
    >
      <span class="text-sm font-medium text-sand-50/90">{room.name[locale]}</span>
    </div>
  ) : (
    <img
      src={room.image}
      alt={room.name[locale]}
      class="aspect-[4/3] w-full object-cover transition group-hover:scale-[1.02]"
      loading="lazy"
      width="800"
      height="600"
    />
  )}
  <div class="flex flex-1 flex-col gap-3 p-6">
    <div class="flex items-start justify-between gap-4">
      <h3 class="text-xl text-ocean-900">{room.name[locale]}</h3>
      <p class="shrink-0 text-lg font-semibold text-ocean-700">
        {formatPrice(room.priceMxn, locale)}
        <span class="block text-xs font-normal text-ocean-600/70">{labels.perNight}</span>
      </p>
    </div>
    <p class="text-sm text-ocean-800/80">{room.description[locale]}</p>
    <p class="text-sm text-ocean-700">
      <span class="font-medium">{labels.idealFor} {room.capacity} {labels.guests}</span>
      · {room.beds[locale]}
    </p>
    <a
      href={contactHref}
      class="mt-auto inline-flex items-center justify-center rounded-lg bg-ocean-700 px-4 py-2.5 text-sm font-medium text-white transition hover:bg-ocean-800"
    >
      {reserveLabel}
    </a>
  </div>
</article>

---
import type { Locale } from '../i18n';
import { getUi } from '../i18n';
import { telUrl } from '../lib/utils';
import site from '../data/site.json';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getUi(locale);
const privacyHref = locale === 'es' ? '/aviso-de-privacidad' : '/en/privacy';
const address = site.address[locale];
---

<footer class="border-t border-sand-200 bg-ocean-900 text-sand-100">
  <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:px-6 md:grid-cols-3">
    <div>
      <p class="font-display text-xl font-semibold">Mareva Playa</p>
      <p class="mt-2 text-sm text-sand-200/80">{site.tagline[locale]}</p>
    </div>
    <div>
      <p class="text-sm font-medium">{locale === 'es' ? 'Contacto' : 'Contact'}</p>
      <ul class="mt-3 space-y-2 text-sm text-sand-200/90">
        <li>
          <a href={telUrl(site.phone)} class="hover:text-white">{site.phoneDisplay}</a>
        </li>
        <li>
          <a href={`mailto:${site.email.info}`} class="hover:text-white">{site.email.info}</a>
        </li>
        <li>
          <a href={`mailto:${site.email.reservations}`} class="hover:text-white"
            >{site.email.reservations}</a
          >
        </li>
        <li class="pt-1">{address}</li>
      </ul>
    </div>
    <div>
      <p class="text-sm font-medium">{locale === 'es' ? 'Enlaces' : 'Links'}</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li>
          <a
            href={site.googleReviewsUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sand-200/90 hover:text-white"
          >
            {t.footer.reviews}
          </a>
        </li>
        <li>
          <a href={privacyHref} class="text-sand-200/90 hover:text-white">{t.footer.privacy}</a>
        </li>
      </ul>
    </div>
  </div>
  <div class="border-t border-ocean-800 py-4 text-center text-xs text-sand-200/60">
    © {new Date().getFullYear()} Mareva Playa. {t.footer.rights}.
  </div>
</footer>

---
import type { Locale } from '../i18n';
import { getUi, navLinks, getAlternatePath } from '../i18n';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const t = getUi(locale);
const links = navLinks(locale);
const altLocale = locale === 'es' ? 'en' : 'es';
const altHref = getAlternatePath(currentPath, altLocale);
const homeHref = locale === 'es' ? '/' : '/en/';
---

<header class="sticky top-0 z-40 border-b border-sand-200/80 bg-sand-50/95 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-4 sm:px-6">
    <a href={homeHref} class="font-display text-xl font-semibold text-ocean-800 sm:text-2xl">
      Mareva Playa
    </a>

    <nav class="hidden items-center gap-6 md:flex" aria-label="Main">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium transition hover:text-ocean-600',
              currentPath === link.href || currentPath === link.href.replace(/\/$/, '')
                ? 'text-ocean-700'
                : 'text-ocean-900/70',
            ]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3">
      <a
        href={altHref}
        class="rounded-lg border border-sand-200 px-3 py-1.5 text-xs font-medium text-ocean-700 transition hover:bg-white"
        hreflang={altLocale}
      >
        {t.langSwitch}
      </a>

      <button
        type="button"
        id="menu-toggle"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg border border-sand-200 md:hidden"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Menu"
      >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    class="hidden border-t border-sand-200 bg-sand-50 px-4 py-4 md:hidden"
    aria-label="Mobile"
  >
    <ul class="flex flex-col gap-3">
      {
        links.map((link) => (
          <li>
            <a href={link.href} class="block py-2 text-sm font-medium text-ocean-800">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(open));
  });
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>

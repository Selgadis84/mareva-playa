---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import ContactForm from '../../components/ContactForm.astro';
import { getUi } from '../../i18n';
import { whatsappUrl, telUrl, hotelJsonLd } from '../../lib/utils';
import site from '../../data/site.json';

const locale = 'en' as const;
const t = getUi(locale);
const waMessage = 'Hello, I would like to book at Mareva Playa.';
---

<BaseLayout
  locale={locale}
  title={`${t.pages.contact.title} — Mareva Playa`}
  description={t.pages.contact.description}
  currentPath="/en/contact"
  jsonLd={hotelJsonLd(locale)}
>
  <PageHero title={t.pages.contact.title} subtitle={t.pages.contact.description} />
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="text-xl font-semibold text-ocean-900">{t.pages.contact.reservationTitle}</h2>
        <p class="mt-4 text-ocean-800/85">{site.reservationPolicy.en}</p>

        <ul class="mt-8 space-y-4">
          <li>
            <a
              href={whatsappUrl(site.whatsapp, waMessage)}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 rounded-lg bg-[#25D366] px-5 py-3 text-sm font-medium text-white"
            >
              {t.cta.whatsapp}: {site.phoneDisplay}
            </a>
          </li>
          <li>
            <a href={telUrl(site.phone)} class="text-ocean-700 hover:underline">{t.cta.call}: {site.phoneDisplay}</a>
          </li>
          <li>
            <a href={`mailto:${site.email.info}`} class="text-ocean-700 hover:underline">{site.email.info}</a>
          </li>
          <li>
            <a href={`mailto:${site.email.reservations}`} class="text-ocean-700 hover:underline"
              >{site.email.reservations}</a
            >
          </li>
        </ul>

        <p class="mt-8 text-sm text-ocean-700">{site.address.en}</p>
        <a
          href={site.googleReviewsUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-4 inline-block text-sm font-medium text-ocean-700 hover:underline"
        >
          {t.footer.reviews} →
        </a>
      </div>

      <div class="rounded-2xl border border-sand-200 bg-white p-6 shadow-sm md:p-8">
        <h2 class="mb-6 text-xl font-semibold text-ocean-900">{t.pages.contact.formTitle}</h2>
        <ContactForm locale={locale} privacyHref="/en/privacy" />
      </div>
    </div>
  </section>
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getUi } from '../../i18n';
import amenities from '../../data/amenities.json';

const locale = 'en' as const;
const t = getUi(locale);
---

<BaseLayout
  locale={locale}
  title={`${t.pages.services.title} — Mareva Playa`}
  description={t.pages.services.description}
  currentPath="/en/services"
>
  <PageHero title={t.pages.services.title} subtitle={t.pages.services.description} />
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-xl font-semibold text-ocean-900">{t.pages.services.coreTitle}</h2>
    <ul class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        amenities.core.map((a) => (
          <li class="rounded-2xl border border-sand-200 bg-white p-6 text-center shadow-sm">
            <p class="font-medium text-ocean-800">{a.name.en}</p>
          </li>
        ))
      }
    </ul>

    <h2 class="mt-16 text-xl font-semibold text-ocean-900">{t.pages.services.expTitle}</h2>
    <ul class="mt-8 flex flex-wrap gap-3">
      {
        amenities.experiences.map((a) => (
          <li class="rounded-full bg-ocean-700 px-4 py-2 text-sm font-medium text-white">
            {a.name.en}
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>

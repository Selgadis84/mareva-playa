---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import { getUi } from '../../i18n';
import site from '../../data/site.json';

const locale = 'en' as const;
const t = getUi(locale);
const lastUpdated = 'July 5, 2026';
---

<BaseLayout
  locale={locale}
  title={`${t.pages.privacy.title} — Mareva Playa`}
  description={t.pages.privacy.description}
  currentPath="/en/privacy"
>
  <PageHero title={t.pages.privacy.title} />
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <p class="text-sm text-ocean-700">Last updated: {lastUpdated}</p>

    <h2 class="mt-10 text-xl text-ocean-900">1. Data controller</h2>
    <p class="text-ocean-800/90">
      Mareva Playa, located at {site.address.en}, is responsible for processing your personal data.
      Contact: <a href={`mailto:${site.email.info}`} class="text-ocean-700 underline">{site.email.info}</a>.
    </p>

    <h2 class="mt-10 text-xl text-ocean-900">2. Data we collect</h2>
    <p class="text-ocean-800/90">
      Through the contact form and communication channels we collect: name, email, phone, proposed stay dates, and
      message. This data is used solely to respond to inquiries and reservation requests.
    </p>

    <h2 class="mt-10 text-xl text-ocean-900">3. Purposes</h2>
    <ul class="mt-4 list-disc space-y-2 pl-6 text-ocean-800/90">
      <li>Respond to inquiries and reservation requests.</li>
      <li>Communicate via email, phone, or WhatsApp regarding your stay.</li>
      <li>Comply with applicable legal obligations.</li>
    </ul>

    <h2 class="mt-10 text-xl text-ocean-900">4. Data sharing</h2>
    <p class="text-ocean-800/90">
      We do not sell or share your data with third parties for commercial purposes. We may use service providers
      (e.g., form processing) acting as processors under confidentiality agreements.
    </p>

    <h2 class="mt-10 text-xl text-ocean-900">5. Your rights</h2>
    <p class="text-ocean-800/90">
      Under Mexican law (LFPDPPP), you may access, rectify, cancel, or object to the processing of your data, or
      revoke consent, by contacting <a href={`mailto:${site.email.info}`} class="text-ocean-700 underline">{site.email.info}</a>. You may also file
      a complaint with the INAI.
    </p>

    <h2 class="mt-10 text-xl text-ocean-900">6. Retention</h2>
    <p class="text-ocean-800/90">We retain your data as long as necessary for the stated purposes and as required by applicable law.</p>

    <h2 class="mt-10 text-xl text-ocean-900">7. Cookies and analytics</h2>
    <p class="text-ocean-800/90">
      This site may use privacy-friendly analytics (e.g., Cloudflare Web Analytics) without invasive tracking cookies.
      The contact form may include anti-spam protection (Cloudflare Turnstile).
    </p>

    <h2 class="mt-10 text-xl text-ocean-900">8. Changes</h2>
    <p class="text-ocean-800/90">We may update this notice. The current version will always be published on this page.</p>
  </article>
</BaseLayout>

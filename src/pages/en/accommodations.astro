---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHero from '../../components/PageHero.astro';
import RoomCard from '../../components/RoomCard.astro';
import { getUi } from '../../i18n';
import rooms from '../../data/rooms.json';

const locale = 'en' as const;
const t = getUi(locale);
---

<BaseLayout
  locale={locale}
  title={`${t.pages.rooms.title} — Mareva Playa`}
  description={t.pages.rooms.description}
  currentPath="/en/accommodations"
>
  <PageHero title={t.pages.rooms.title} subtitle={t.pages.rooms.description} />
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="grid gap-8 md:grid-cols-2">
      {
        rooms.map((room) => (
          <RoomCard
            room={room}
            locale={locale}
            labels={t.pages.rooms}
            contactHref="/en/contact"
            reserveLabel={t.cta.reserve}
          />
        ))
      }
    </div>
  </section>
</BaseLayout>
